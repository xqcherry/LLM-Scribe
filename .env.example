########################################
# LLM-Scribe 环境变量示例（模板文件）
# 复制为 .env 后再填写真实配置：
#   cp .env.example .env
########################################

########## 数据库配置 ##########
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=llm_scribe
DB_CHARSET=utf8mb4

########## Moonshot LLM ##########
# 在 https://moonshot.cn/ 获取 API Key
MOONSHOT_API_KEY=your_moonshot_api_key

########## Redis 缓存 ##########
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# 无密码可留空
REDIS_PASSWORD=

########## ChromaDB 向量库 ##########
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=group_summaries

########## HuggingFace 向量模型 ##########
# 如需使用本地模型，可改为绝对路径
HUGGINGFACE_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
HUGGINGFACE_MODEL_DEVICE=cpu

########## RAG / 缓存策略（可选） ##########
CACHE_SIMILARITY_THRESHOLD=0.85
RETRIEVAL_SCORE_THRESHOLD=0.7
RETRIEVAL_USE_COMPRESSION=true
RETRIEVAL_USE_HYBRID_SEARCH=true

########## 忽略的 QQ 号（可选） ##########
# 逗号分隔，例如：IGNORE_QQ=123456,654321
IGNORE_QQ=