########################################
# LLM-Scribe 环境变量示例（模板文件）
# 复制为 .env 后再填写真实配置：
#   cp .env.example .env
########################################


########## 数据库配置 ##########
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=xxxx
DB_PASSWORD=xxxx
DB_NAME=xxx
DB_CHARSET=utf8mb4


########## Moonshot LLM ##########
# 在 https://moonshot.cn/ 获取 API Key
LLM_API_KEY=xxx


########## 忽略的 QQ 号（可选） ##########
# 逗号分隔，例如：IGNORE_QQ=123456,654321
IGNORE_QQ=